# === Telegram ===
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=

# === AI Provider API Keys ===
# Claude CLI reads ANTHROPIC_API_KEY automatically.
# For OpenAI-compatible providers, set OPENAI_API_KEY and/or AI_BASE_URL.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1

# === Bot defaults ===
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_DEFAULT_EFFORT=high
CLAUDE_DEFAULT_THINKING=adaptive
CLAUDE_CLI_TIMEOUT_MS=360000
CLAUDE_CONTEXT_MESSAGES=10

# === Concurrency ===
MAX_CONCURRENT_CLI_PROCESSES=3
RATE_LIMIT_REQUESTS_PER_MINUTE=10

# === Dashboard ===
WEB_PORT=3000
# Required for dashboard API access. Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# === Session compaction ===
COMPACT_THRESHOLD=20
COMPACT_KEEP_RECENT=6
COMPACT_ENABLED=true

# === Working dirs (inside container) ===
ALLOWED_WORKING_DIRS=/app/data
